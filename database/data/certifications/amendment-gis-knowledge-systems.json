          "title": "Spatial analysis foundations",
          "minutes": 35,
          "summary": "Use location to find service gaps, patterns, clusters, and access constraints.",
          "learn": [
            "Spatial analysis answers questions that ordinary tables cannot answer alone: what is near, what overlaps, what clusters, and what areas are underserved.",
            "For CertPath projects, this matters when mapping MSME access to training venues, financial services, internet, roads, markets, and device-financing agents.",
            "Strong GIS evidence should connect map outputs to decisions, not only display points on a map."
          ],
          "example": {
            "intro": "A simple accessibility workflow:",
            "code": "MSME points -> buffer training venues -> intersect with roads -> compare covered and uncovered parishes -> map service gaps",
            "explanation": "The output shows which areas may need outreach, new partners, or mobile-service delivery."
          },
          "exercise": {
            "prompt": "Sketch a GIS workflow for identifying underserved MSME locations.",
            "starter": "Input layers:\nAnalysis steps:\nMap outputs:\nDecision supported:",
            "answerGuide": "Mention point locations, administrative boundaries, service locations, travel/access assumptions, and a service-gap map."
          },
          "quiz": {
            "prompt": "What makes GIS analysis different from a normal spreadsheet summary?",
            "options": ["It ignores location", "It uses spatial relationships such as distance, overlap, and containment", "It only stores certificates", "It prevents mapping"],
            "answer": 1,
            "explanation": "GIS analysis uses spatial relationships to answer location-aware questions."
          },
          "reference": ["Spatial joins connect attributes based on location.", "Buffers estimate proximity.", "Good maps should support decisions."],
          "proofTask": "Create a one-page concept map for an MSME service coverage analysis."
        }
      ]
